{
  "name": "cursor-engineering-coach",
  "displayName": "Cursor Engineering Coach",
  "description": "Analyze your Cursor IDE usage — chat sessions, agent runs, generated code, and context health. Read-only, zero telemetry.",
  "version": "0.1.0",
  "publisher": "cursor-engineering-coach",
  "license": "MIT",
  "icon": "assets/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/prd-dat-tran/Cursor-Engineering-Coach.git"
  },
  "bugs": {
    "url": "https://github.com/prd-dat-tran/Cursor-Engineering-Coach/issues"
  },
  "engines": {
    "vscode": "^1.105.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "cursor",
    "analytics",
    "productivity",
    "coaching",
    "anti-patterns",
    "context-health"
  ],
  "activationEvents": [
    "onCommand:cursorEngineeringCoach.open",
    "onCommand:cursorEngineeringCoach.reload",
    "onCommand:cursorEngineeringCoach.exportSummary",
    "onCommand:cursorEngineeringCoach.reviewLocalRules",
    "onView:cursorEngineeringCoach.welcome"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorEngineeringCoach.open",
        "title": "Cursor Engineering Coach: Open Dashboard",
        "icon": "$(graph)"
      },
      {
        "command": "cursorEngineeringCoach.reload",
        "title": "Cursor Engineering Coach: Reload Data",
        "icon": "$(refresh)"
      },
      {
        "command": "cursorEngineeringCoach.exportSummary",
        "title": "Cursor Engineering Coach: Export Summary",
        "icon": "$(export)"
      },
      {
        "command": "cursorEngineeringCoach.reviewLocalRules",
        "title": "Cursor Engineering Coach: Review Local Rule Approvals",
        "icon": "$(shield)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorEngineeringCoach",
          "title": "Cursor Engineering Coach",
          "icon": "$(graph)"
        }
      ]
    },
    "views": {
      "cursorEngineeringCoach": [
        {
          "id": "cursorEngineeringCoach.welcome",
          "name": "Dashboard",
          "type": "webview"
        }
      ]
    },
    "chatParticipants": [
      {
        "id": "cursorEngineeringCoach.coach",
        "fullName": "Cursor Engineering Coach",
        "name": "coach",
        "description": "Your Cursor coach — analyze usage patterns, get improvement tips, and track progress",
        "isSticky": true,
        "commands": [
          { "name": "summary", "description": "Get a quick summary of your Cursor usage" },
          { "name": "improve", "description": "Get improvement recommendations" },
          { "name": "compare", "description": "Compare your Cursor agent modes" },
          { "name": "flow", "description": "Analyze your flow & focus" }
        ]
      }
    ],
    "languageModelTools": [
      {
        "name": "coach_summary",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Usage Summary",
        "modelDescription": "Get a high-level summary of Cursor IDE usage including session counts, recommendations, and top anti-patterns.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      },
      {
        "name": "coach_activity",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Daily Activity",
        "modelDescription": "Get daily activity data including requests, LOC, and sessions.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      },
      {
        "name": "coach_credits",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Usage Credits",
        "modelDescription": "Get usage credits with per-model breakdown, daily trend, and most expensive requests.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      },
      {
        "name": "coach_codeProduction",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Code Production",
        "modelDescription": "Get code production metrics: AI vs user LOC, language breakdown, workspace distribution.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      },
      {
        "name": "coach_flow",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Flow State",
        "modelDescription": "Get flow state analysis: deep work scores, best hours, follow-up latency, session continuity.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      },
      {
        "name": "coach_patterns",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Anti-Patterns",
        "modelDescription": "Get detected anti-patterns and practice recommendations with severity and trends.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      },
      {
        "name": "coach_insights",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Insights",
        "modelDescription": "Get advanced insights: learning velocity, intent classification, prompt maturity, sustainable pace.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      },
      {
        "name": "coach_wellbeing",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Work-Life Balance",
        "modelDescription": "Get work-life balance score, time distribution, weekend ratio, and burnout risk.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      },
      {
        "name": "coach_workflows",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Workflows",
        "modelDescription": "Get repeated workflow clusters that could be automated, with draft skill suggestions.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      },
      {
        "name": "coach_modeComparison",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Mode Comparison",
        "modelDescription": "Compare Cursor agent modes side-by-side: sessions, requests, LOC, models, cancel rates.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      },
      {
        "name": "coach_sessions",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Sessions",
        "modelDescription": "Browse or search individual coding sessions. Use sessionId for detail, or page/search to browse.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "sessionId": { "type": "string", "description": "Get detail for a specific session" },
            "page": { "type": "number", "description": "Page number (1-based)" },
            "pageSize": { "type": "number", "description": "Sessions per page (max 50)" },
            "search": { "type": "string", "description": "Search term for workspace or message content" },
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      },
      {
        "name": "coach_contextHealth",
        "tags": ["cursor-engineering-coach"],
        "displayName": "Coach: Context Health",
        "modelDescription": "Get context management health: compaction, config scores, agentic readiness, instruction quality.",
        "inputSchema": {
          "type": "object",
          "properties": {
            "fromDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range start" },
            "toDate": { "type": "string", "description": "ISO date (YYYY-MM-DD) for range end" },
            "workspaceId": { "type": "string", "description": "Filter to a workspace ID" }
          }
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "lint": "eslint src/",
    "bench": "vitest bench",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "analyze:data-inventory": "npx tsx scripts/data-inventory.ts",
    "analyze:token-inventory": "npx tsx scripts/token-inventory.ts --save",
    "analyze:context-composition": "npx tsx scripts/explore-context-composition.ts",
    "analyze:e2e-real-data": "npx tsx scripts/e2e-real-data.ts",
    "analyze:catalog-fetch": "node scripts/test-catalog-fetch.mjs",
    "smoke-test": "node scripts/smoke-test.mjs",
    "package": "node scripts/package-readme-swap.mjs",
    "spellcheck": "cspell \"src/**/*.ts\" \"docs/**/*.md\" \"*.md\"",
    "knip": "knip",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run spellcheck && npm run knip && npm run test",
    "check-size": "node scripts/check-bundle-size.mjs",
    "test:e2e": "npx playwright test",
    "lockfile-lint": "lockfile-lint",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "cspell --no-must-find-files"
    ],
    "*.md": [
      "cspell --no-must-find-files"
    ]
  },
  "engineStrict": true,
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@playwright/test": "1.60.0",
    "@types/node": "25.9.1",
    "@types/vscode": "1.105.0",
    "@vitest/coverage-v8": "4.1.6",
    "@vscode/vsce": "3.9.1",
    "cspell": "10.0.0",
    "esbuild": "0.28.0",
    "eslint": "10.4.0",
    "eslint-plugin-import-x": "4.16.2",
    "eslint-plugin-no-unsanitized": "4.1.5",
    "eslint-plugin-unicorn": "64.0.0",
    "husky": "9.1.7",
    "jsdom": "29.1.1",
    "knip": "6.14.1",
    "lint-staged": "17.0.5",
    "lockfile-lint": "5.0.0",
    "preact-render-to-string": "6.7.0",
    "serve": "14.2.6",
    "typescript": "6.0.3",
    "typescript-eslint": "8.59.4",
    "vitest": "4.1.6"
  },
  "dependencies": {
    "chart.js": "4.5.1",
    "chartjs-chart-treemap": "3.1.0",
    "htm": "3.1.1",
    "leo-profanity": "1.9.0",
    "preact": "10.29.2",
    "zod": "4.4.3"
  }
}
