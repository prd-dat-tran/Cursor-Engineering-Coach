# =============================================================================
# .cursorignore — files Cursor should NOT index, embed, or send as context.
#
# Goal: keep agent context focused on *authored* code + docs. Everything below
# is either generated, lockfiles, binary, secret, or otherwise high-noise.
# =============================================================================

# ── Dependencies & build output ──────────────────────────────────────────────
node_modules/
dist/
*.vsix
.vscode-test/

# ── Lockfiles (huge, dilute embeddings, agent should never hand-edit them) ──
package-lock.json
yarn.lock
pnpm-lock.yaml

# ── Hugo / docs build artifacts ──────────────────────────────────────────────
docs/public/
docs/.hugo_build.lock
docs/resources/_gen/
docs/cursor-engineering-coach.pdf
docs/security-audit.md

# ── Test artifacts (regenerated by every `npm test`) ─────────────────────────
test-results/
playwright-report/
coverage/
.vitest-cache/
**/__snapshots__/

# ── Runtime cache (written by the extension at ~/.cursor-engineering-coach/) ─
.cursor-engineering-coach/
.copilot-analytics-cache/

# ── Editor / OS junk ─────────────────────────────────────────────────────────
.DS_Store
**/.DS_Store
.idea/
*.swp
*.swo

# ── Local / personal scratch space ───────────────────────────────────────────
local/
test_output.txt
PROPOSED_FIXES.md
README.github.md
marketing/

# ── Secrets (defense in depth — these should never be committed anyway) ──────
.env
.env.*
*.pem
*.key
*.p12
credentials.json

# ── Binary assets (kept for runtime, not for the agent) ──────────────────────
assets/*.png
assets/*.jpg
assets/*.jpeg
assets/*.gif
assets/*.ico
**/*.woff
**/*.woff2

# ── Git internals ────────────────────────────────────────────────────────────
.git/
